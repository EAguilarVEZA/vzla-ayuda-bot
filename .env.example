# --- Anthropic (the bot's brain) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Haiku = cheap + fast for high volume; bump to claude-sonnet-4-6 for quality.
BOT_MODEL=claude-haiku-4-5

# Public one-tap entry link people share (set once you have a Business number).
PUBLIC_BOT_LINK=https://wa.me/<your-number>?text=Hola

# --- Twilio (WhatsApp + SMS channel) ---
# From the Twilio console. For the WhatsApp sandbox, FROM is the sandbox number.
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- App ---
DB_PATH=ayuda.db

# --- Native interactive-list menu (optional; needs WhatsApp Business API) ---
# Leave 0 on the sandbox: the menu renders as grouped text. Set 1 once you have
# a Business sender to upgrade the menu to a native scrollable list.
WHATSAPP_INTERACTIVE=0
# "cloud" = Meta WhatsApp Cloud API (inline JSON); "twilio" = Content template.
WHATSAPP_PROVIDER=cloud
# Cloud API creds (only if WHATSAPP_PROVIDER=cloud):
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_ID=
# Twilio list-picker Content template SID (only if WHATSAPP_PROVIDER=twilio):
TWILIO_LIST_CONTENT_SID=
